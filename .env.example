# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/publishable key ONLY — NEVER use the service-role key here (bypasses RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ── Notes ─────────────────────────────────────────────────────────────────────
# Edge Function secrets (set via: supabase secrets set KEY=value):
#   BREVO_API_KEY           — Brevo transactional email
#   GOOGLE_SHEETS_WEBHOOK_URL — CRM relay webhook
#   STAFF_PIN               — PIN de acesso ao painel de gestão
#   WHITELIST_EMAILS        — Emails staff que ignoram o cooldown (server-side)
