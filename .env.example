# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/publishable key ONLY — NEVER use the service-role key here (bypasses RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ── Notes ─────────────────────────────────────────────────────────────────────
# Edge Function secrets (set via: supabase secrets set KEY=value):
#   BREVO_API_KEY            — Brevo transactional email
#   GOOGLE_SHEETS_WEBHOOK_URL — CRM relay webhook (optional)
#   PII_ENCRYPTION_KEY       — AES key for nome/cognome at rest (optional)
#   WHITELIST_EMAILS         — Staff emails bypassing cooldown (comma-separated)
#   ALLOWED_ORIGIN           — CORS allowlist (e.g. https://your-domain.com)
#   WEBHOOK_SECRET           — Shared secret for the Postgres webhook
#                              Add as header "x-webhook-secret: <value>" in
#                              Supabase Dashboard → Database → Webhooks.
#   STAFF_PIN_HASH           — Initial bcrypt hash inserted into app_config
#                              (one-shot setup, see migration 20260407000001).
