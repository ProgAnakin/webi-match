# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/publishable key ONLY — NEVER use the service-role key here (bypasses RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ── Sentry (optional but recommended for production) ─────────────────────────
# Found in: Sentry → Project Settings → Client Keys (DSN)
# When set, src/main.tsx initialises @sentry/react with browserTracing (20%
# sample rate) and Replay on errors (100% on error sessions). Leave unset for
# local dev — Sentry then no-ops silently.
VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# ── Edge Function secrets ──────────────────────────────────────────────────────
# Set via Supabase Dashboard → Edge Functions → <function> → Secrets
# (or: npx supabase secrets set KEY=value)
#
# STAFF_PIN  ★ REQUIRED for PIN login to work ★
#   The plaintext staff PIN used by AdminPinOverlay and MatchResult change-email.
#   Set on the "verify-pin" Edge Function.
#   Example: STAFF_PIN=0123
#   The Edge Function compares it directly (constant-time) — the value never
#   reaches the client.  Fallback: if this secret is absent, the function tries
#   bcrypt comparison against app_config.staff_pin_hash in the database
#   (requires migration 20260507000004 to have been run in the SQL Editor).
#
# BREVO_API_KEY            — Brevo transactional email
# GOOGLE_SHEETS_WEBHOOK_URL — CRM relay webhook (optional)
# PII_ENCRYPTION_KEY       — AES key for nome/cognome at rest (optional)
# WHITELIST_EMAILS         — Staff emails bypassing cooldown (comma-separated)
# ALLOWED_ORIGIN           — CORS allowlist (e.g. https://your-domain.com)
# WEBHOOK_SECRET  ★ RECOMMENDED ★
#   Shared secret for the Postgres webhook → on-session-created.
#   Add as HTTP header "x-webhook-secret: <value>" in
#   Supabase Dashboard → Database → Webhooks → on-session-created.
#   Without it, anyone who learns the function URL can trigger arbitrary
#   email sends and discount-code generation.
